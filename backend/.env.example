# Backend environment example
# MongoDB connection (used by backend/config/Database.js)
DATABASE_URI=mongodb://localhost:27017/tictactoe

# JWT secret used across the app
SECRET_KEY=your_jwt_secret_here

# Mailer credentials used by nodemailer (optional)
COMPANY_MAIL=your_email@gmail.com
COMPANY_PASSWORD=your_email_password

# Optional: Cloudinary or other third-party keys if used
# CLOUDINARY_URL=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
